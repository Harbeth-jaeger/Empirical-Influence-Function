# Copy to .env for local development. Do not commit real secrets.

# External workspace layout
EIF_PROJECT_DIR=/mnt/nvme0n1/wenhao/projects/Empirical-Influence-Function
EIF_DATA_DIR=/mnt/nvme0n1/wenhao/datasets/Empirical-Influence-Function
EIF_MODEL_DIR=/mnt/nvme0n1/wenhao/models/Empirical-Influence-Function
EIF_RUN_DIR=/mnt/nvme0n1/wenhao/runs/Empirical-Influence-Function
HF_HOME=/mnt/nvme0n1/wenhao/hf_cache
TRANSFORMERS_CACHE=/mnt/nvme0n1/wenhao/hf_cache
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
MAMBA_ROOT_PREFIX=/mnt/nvme0n1/wenhao/envs/micromamba

# Model/cache paths. Both defaults point to the 7B base model used by the current workflow.
# MODEL_PATH is kept for scripts that use it as tokenizer/base-model path;
# BASE_MODEL_PATH is the explicit training/evaluation base-model variable.
MODEL_PATH=/mnt/nvme0n1/wenhao/models/Empirical-Influence-Function/Qwen2.5-Coder-7B-Instruct
BASE_MODEL_PATH=/mnt/nvme0n1/wenhao/models/Empirical-Influence-Function/Qwen2.5-Coder-7B-Instruct
TRAIN_DATA=/mnt/nvme0n1/wenhao/datasets/Empirical-Influence-Function/processed/go_singleline_fim_exp/train_data/go_single_train_v2_graphsignal_10k_compact.json

# OpenAI-compatible annotation model
OPENAI_BASE_URL=https://example.com/v1
OPENAI_API_KEY=<your_api_key>
ANNOTATE_MODEL=<your_model_name>

# Optional Huawei gateway headers
REQUIRE_HUAWEI_GATEWAY=0
HW_ID=<your_hw_id>
HW_APPKEY=<your_hw_appkey>
HW_APP_ID=<your_hw_app_id>
HW_SCENE=test
HW_OPERATOR=<your_operator>

# Training defaults
WANDB_PROJECT=code-corr-saliency
CUDA_VISIBLE_DEVICES=0
