{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "train saliency loss",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/train/train.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.micromamba/envs/eif-bench/bin/python",
            "justMyCode": false,
            "args": [
                "--model_name_or_path",
                "Qwen/Qwen2.5-Coder-1.5B-Instruct",
                "--data_path",
                "data/benchmarks/sft_data/ours_graphsignal_train_first500.json",
                "--output_dir",
                "outputs/debug_saliency_loss",
                "--max_steps",
                "1",
                "--per_device_train_batch_size",
                "1",
                "--gradient_accumulation_steps",
                "1",
                "--learning_rate",
                "2e-5",
                "--warmup_ratio",
                "0.03",
                "--lr_scheduler_type",
                "cosine",
                "--dataloader_num_workers",
                "0",
                "--logging_steps",
                "1",
                "--save_strategy",
                "no",
                "--eval_strategy",
                "no",
                "--report_to",
                "none",
                "--disable_tqdm",
                "true",
                "--remove_unused_columns",
                "false",
                "--bf16",
                "true",
                "--max_len",
                "8192",
                "--saliency_lambda",
                "1.0",
                "--saliency_alpha",
                "0.5",
                "--saliency_eps",
                "1e-8"
            ],
            "env": {
                "CUDA_VISIBLE_DEVICES": "0",
                "WANDB_DISABLED": "true",
                "HF_HUB_OFFLINE": "1",
                "TRANSFORMERS_OFFLINE": "1",
                "TOKENIZERS_PARALLELISM": "false",
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}