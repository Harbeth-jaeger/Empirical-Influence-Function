{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "train saliency loss",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/train/train.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.micromamba/envs/eif-bench/bin/python",
            "justMyCode": false,
            "args": [
                "--model_name_or_path",
                "Qwen/Qwen2.5-Coder-1.5B-Instruct",
                "--data_path",
                "data/benchmarks/sft_data/ours_graphsignal_train_first500.json",
                "--output_dir",
                "outputs/debug_saliency_loss",
                "--max_steps",
                "1",
                "--per_device_train_batch_size",
                "1",
                "--gradient_accumulation_steps",
                "1",
                "--learning_rate",
                "2e-5",
                "--warmup_ratio",
                "0.03",
                "--lr_scheduler_type",
                "cosine",
                "--dataloader_num_workers",
                "0",
                "--logging_steps",
                "1",
                "--save_strategy",
                "no",
                "--eval_strategy",
                "no",
                "--report_to",
                "none",
                "--disable_tqdm",
                "true",
                "--remove_unused_columns",
                "false",
                "--bf16",
                "true",
                "--max_len",
                "8192",
                "--saliency_lambda",
                "1.0",
                "--saliency_alpha",
                "0.5",
                "--saliency_eps",
                "1e-8"
            ],
            "env": {
                "CUDA_VISIBLE_DEVICES": "0",
                "WANDB_DISABLED": "true",
                "HF_HUB_OFFLINE": "1",
                "TRANSFORMERS_OFFLINE": "1",
                "TOKENIZERS_PARALLELISM": "false",
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "debug annotate one row",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/go_singleline_fim_exp/annotate_chatml_with_src_annotate.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.micromamba/envs/eif-bench/bin/python",
            "justMyCode": false,
            "args": [
                "--input_path",
                "data/go_singleline_fim_exp/train_data/go_single_train_v2_chatml.jsonl",
                "--output_path",
                "outputs/debug_annotate/debug_one_row.jsonl",
                "--model_name_or_path",
                "models/Qwen2.5-Coder-7B-Instruct",
                "--model_max_length",
                "4096",
                "--max_rows",
                "1",
                "--num_workers",
                "1",
                "--max_rounds",
                "1",
                "--annotation_mode",
                "oneshot",
                "--max_teacher_edges",
                "16",
                "--annotation_cache_path",
                "outputs/debug_annotate/debug_one_row.annotation_cache.jsonl",
                "--flush_every",
                "1",
                "--overwrite_cache"
            ],
            "env": {
                "CUDA_VISIBLE_DEVICES": "",
                "HF_HUB_OFFLINE": "1",
                "TRANSFORMERS_OFFLINE": "1",
                "TOKENIZERS_PARALLELISM": "false",
                "PYTHONPATH": "${workspaceFolder}",
                "OPENAI_API_KEY": "${env:OPENAI_API_KEY}",
                "OPENAI_BASE_URL": "${env:OPENAI_BASE_URL}",
                "ANNOTATE_MODEL": "${env:ANNOTATE_MODEL}",
                "ANNOTATE_MAX_TOKENS": "1024",
                "ANNOTATE_MIN_REQUEST_INTERVAL": "1.2",
                "ANNOTATE_MAX_RETRIES": "1",
                "ANNOTATE_RETRY_BASE_SLEEP": "3",
                "ANNOTATE_REQUEST_TIMEOUT": "60"
            }
        }
    ]
}